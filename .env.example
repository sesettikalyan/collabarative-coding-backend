# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# Get your MongoDB Atlas connection string from https://www.mongodb.com/cloud/atlas (free tier)
MONGODB_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/collab-coding?retryWrites=true&w=majority

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d

# Frontend Configuration (CORS)
FRONTEND_URL=http://localhost:5173

# Judge0 API Configuration (FREE tier)
# Get free API key from https://rapidapi.com/judge0-judge0-default/api/judge0-ce
# Judge0 free tier: 50 requests/day, sufficient for development
JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
JUDGE0_API_KEY=your-free-judge0-api-key

# Logging
LOG_LEVEL=debug
